# ── Google Gemini API ────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud Firestore ───────────────────────────────────────────────────
# Your GCP project ID (e.g. "pathstream-ai-prod")
FIRESTORE_PROJECT_ID=

# Path to your GCP service account JSON key file (for local dev)
# In Cloud Run, use Workload Identity instead (leave blank).
GOOGLE_APPLICATION_CREDENTIALS=

# ── Stripe Payments ──────────────────────────────────────────────────────────
# Get your key from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=

# ── App Config ───────────────────────────────────────────────────────────────
# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-firebase-app.web.app
PORT=8080
